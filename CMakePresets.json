{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "clang-ninja-debug",
            "displayName": "Clang + Ninja (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain/clang-windows.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "clang-ninja-release",
            "displayName": "Clang + Ninja (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "${sourceDir}/cmake/toolchain/clang-windows.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "configurePreset": "clang-ninja-debug"
        },
        {
            "name": "release",
            "displayName": "Release",
            "configurePreset": "clang-ninja-release"
        }
    ]
}
